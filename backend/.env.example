DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require"
# Optional: direct Neon URL for migrations (omit to auto-strip -pooler from DATABASE_URL)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require"
NODE_ENV="development"
# Use sk_live_ / pk_live_ in production (Render backend service)
CLERK_SECRET_KEY="sk_live_..."
CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_AUTH_MODE="express"
WEBHOOK_SECRET="whsec_..."
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
FRONTEND_URL="http://localhost:5173"
# Optional comma-separated extra origins (e.g. https://pixora-gallery.online)
ALLOWED_ORIGINS=""
MAX_PHOTOS_PER_USER=100
PORT=4000
